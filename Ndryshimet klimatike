<!DOCTYPE html>
<html lang="sq">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sa po e dëmton planetin?</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: linear-gradient(to bottom, #031926, #064663, #0b8793);
      color: white;
      overflow-x: hidden;
    }

    header {
      height: 100vh;
      background: url('https://images.unsplash.com/photo-1441974231531-c6227db76b6e?q=80&w=1600&auto=format&fit=crop') center/cover no-repeat;
      display: flex;
      justify-content: center;
      align-items: center;
      text-align: center;
      position: relative;
    }

    header::before {
      content: "";
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.55);
    }

    .hero {
      position: relative;
      z-index: 2;
      padding: 20px;
      max-width: 800px;
    }

    .hero h1 {
      font-size: 4rem;
      margin-bottom: 20px;
      text-shadow: 0 0 15px rgba(0,0,0,0.6);
    }

    .hero p {
      font-size: 1.4rem;
      line-height: 1.6;
      margin-bottom: 30px;
    }

    .start-btn {
      padding: 16px 35px;
      border: none;
      border-radius: 50px;
      background: #00c853;
      color: white;
      font-size: 1.2rem;
      cursor: pointer;
      transition: 0.3s;
      box-shadow: 0 0 20px rgba(0,200,83,0.6);
    }

    .start-btn:hover {
      transform: scale(1.05);
      background: #00e676;
    }

    .container {
      max-width: 900px;
      margin: auto;
      padding: 60px 20px;
    }

    .question-box {
      background: rgba(255,255,255,0.08);
      padding: 30px;
      border-radius: 25px;
      margin-bottom: 30px;
      backdrop-filter: blur(8px);
      box-shadow: 0 0 20px rgba(0,0,0,0.3);
      transition: 0.3s;
    }

    .question-box:hover {
      transform: translateY(-5px);
    }

    .question-box h2 {
      margin-bottom: 20px;
      font-size: 1.5rem;
      color: #b2ff59;
    }

    .options label {
      display: block;
      margin-bottom: 15px;
      background: rgba(255,255,255,0.1);
      padding: 15px;
      border-radius: 12px;
      cursor: pointer;
      transition: 0.3s;
    }

    .options label:hover {
      background: rgba(255,255,255,0.2);
    }

    input[type="radio"] {
      margin-right: 10px;
    }

    .submit-btn {
      display: block;
      margin: 40px auto;
      padding: 18px 40px;
      border: none;
      border-radius: 50px;
      background: #00c853;
      color: white;
      font-size: 1.3rem;
      cursor: pointer;
      transition: 0.3s;
    }

    .submit-btn:hover {
      background: #00e676;
      transform: scale(1.05);
    }

    #result {
      display: none;
      text-align: center;
      padding: 60px 20px;
      animation: fadeIn 1s ease;
    }

    #result h2 {
      font-size: 3rem;
      margin-bottom: 20px;
    }

    #result p {
      font-size: 1.3rem;
      line-height: 1.8;
      max-width: 700px;
      margin: auto;
    }

    .planet-img {
      width: 250px;
      margin: 30px auto;
      display: block;
      animation: float 4s ease-in-out infinite;
    }

    footer {
      text-align: center;
      padding: 30px;
      background: rgba(0,0,0,0.3);
      margin-top: 60px;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes float {
      0% { transform: translateY(0px); }
      50% { transform: translateY(-10px); }
      100% { transform: translateY(0px); }
    }

    html {
      scroll-behavior: smooth;
    }
  </style>
</head>
<body>

<header>
  <div class="hero">
    <h1>🌍 Sa po e dëmton planetin?</h1>
    <p>
      Çdo veprim që bëjmë lë gjurmë në Tokë.
      Përgjigju pyetjeve dhe zbulo sa ndikojnë zakonet tua në ndryshimet klimatike.
    </p>
    <a href="#quiz">
      <button class="start-btn">Fillo Testin</button>
    </a>
  </div>
</header>

<section class="container" id="quiz">

  <div class="question-box">
    <h2>1. Sa shpesh përdor makinë për distanca të shkurtra?</h2>
    <div class="options">
      <label><input type="radio" name="q1" value="1"> Çdo ditë</label>
      <label><input type="radio" name="q1" value="3"> Shpesh</label>
      <label><input type="radio" name="q1" value="7"> Rrallë</label>
      <label><input type="radio" name="q1" value="10"> Ec / përdor biçikletë</label>
    </div>
  </div>

  <div class="question-box">
    <h2>2. A i fik dritat kur nuk të duhen?</h2>
    <div class="options">
      <label><input type="radio" name="q2" value="10"> Gjithmonë</label>
      <label><input type="radio" name="q2" value="5"> Ndonjëherë</label>
      <label><input type="radio" name="q2" value="1"> Rrallë</label>
    </div>
  </div>

  <div class="question-box">
    <h2>3. Sa shpesh përdor plastikë njëpërdorimshe?</h2>
    <div class="options">
      <label><input type="radio" name="q3" value="1"> Çdo ditë</label>
      <label><input type="radio" name="q3" value="4"> Shpesh</label>
      <label><input type="radio" name="q3" value="7"> Rrallë</label>
      <label><input type="radio" name="q3" value="10"> Pothuajse kurrë</label>
    </div>
  </div>

  <div class="question-box">
    <h2>4. A përpiqesh të reduktosh mbeturinat që krijon çdo ditë?</h2>
    <div class="options">
      <label><input type="radio" name="q4" value="10"> Po, shpesh</label>
      <label><input type="radio" name="q4" value="5"> Ndonjëherë</label>
      <label><input type="radio" name="q4" value="1"> Jo shumë</label>
    </div>
  </div>

  <div class="question-box">
    <h2>5. Sa gjatë bën dush?</h2>
    <div class="options">
      <label><input type="radio" name="q5" value="1"> Mbi 15 minuta</label>
      <label><input type="radio" name="q5" value="6"> 5–10 minuta</label>
      <label><input type="radio" name="q5" value="10"> Më pak se 5 minuta</label>
    </div>
  </div>

  <div class="question-box">
    <h2>6. A përdor qese të ripërdorshme?</h2>
    <div class="options">
      <label><input type="radio" name="q6" value="10"> Gjithmonë</label>
      <label><input type="radio" name="q6" value="5"> Ndonjëherë</label>
      <label><input type="radio" name="q6" value="1"> Asnjëherë</label>
    </div>
  </div>

  <div class="question-box">
    <h2>7. Sa shpesh blen gjëra që nuk të duhen?</h2>
    <div class="options">
      <label><input type="radio" name="q7" value="1"> Shumë shpesh</label>
      <label><input type="radio" name="q7" value="5"> Ndonjëherë</label>
      <label><input type="radio" name="q7" value="10"> Rrallë</label>
    </div>
  </div>

  <div class="question-box">
    <h2>8. A ke mbjellë ndonjëherë pemë ose lule?</h2>
    <div class="options">
      <label><input type="radio" name="q8" value="10"> Po</label>
      <label><input type="radio" name="q8" value="1"> Jo</label>
    </div>
  </div>

  <div class="question-box">
    <h2>9. Çfarë bën kur sheh mbeturina në natyrë?</h2>
    <div class="options">
      <label><input type="radio" name="q9" value="10"> I marr dhe i hedh në kosh</label>
      <label><input type="radio" name="q9" value="5"> Varet nga situata</label>
      <label><input type="radio" name="q9" value="1"> I injoroj</label>
    </div>
  </div>

  <div class="question-box">
    <h2>10. A do ta ndryshoje stilin e jetesës për të shpëtuar planetin?</h2>
    <div class="options">
      <label><input type="radio" name="q10" value="10"> Po, menjëherë</label>
      <label><input type="radio" name="q10" value="5"> Ndoshta</label>
      <label><input type="radio" name="q10" value="1"> Jo</label>
    </div>
  </div>

  <button class="submit-btn" onclick="calculateScore()">Shiko Rezultatin</button>

  <div id="result">
    <img class="planet-img" src="https://cdn-icons-png.flaticon.com/512/4144/4144797.png" alt="Planet">
    <h2 id="resultTitle"></h2>
    <p id="resultText"></p>
  </div>

</section>

<footer>
  🌍 Projekti për Ndryshimet Klimatike | Ruaje Planetin
</footer>

<script>
function calculateScore() {
  let total = 0;

  for (let i = 1; i <= 10; i++) {
    const answer = document.querySelector(`input[name="q${i}"]:checked`);

    if (!answer) {
      alert("Ju lutem përgjigjuni të gjitha pyetjeve!");
      return;
    }

    total += parseInt(answer.value);
  }

  const result = document.getElementById("result");
  const title = document.getElementById("resultTitle");
  const text = document.getElementById("resultText");

  result.style.display = "block";

  if (total <= 40) {
    title.innerHTML = "🟥 Planeti po ndikohet shumë";
    text.innerHTML = "Zakontet tua po ndikojnë negativisht në mjedis. Nëse të gjithë do të jetonin kështu, Toka do të vuante shumë më tepër. Filloni me ndryshime të vogla: përdor më pak plastikë, kurse energji dhe mbro natyrën.";
  }
  else if (total <= 75) {
    title.innerHTML = "🟨 Ka hapësirë për përmirësim";
    text.innerHTML = "Ti tashmë ke disa zakone të mira për planetin, por ende mund të bësh më shumë. Çdo veprim i vogël ka rëndësi për të ardhmen tonë.";
  }
  else {
    title.innerHTML = "🟩 Ti po ndihmon planetin";
    text.innerHTML = "Veprimet tua ndihmojnë për një botë më të pastër dhe më të gjelbër. Nëse më shumë njerëz do të mendonin si ti, e ardhmja do të ishte shumë më e mirë.";
  }

  result.scrollIntoView({ behavior: 'smooth' });
}
</script>

</body>
</html>
